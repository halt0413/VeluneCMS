{
  "name": "@velune-cms/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "env TSX_TSCONFIG_PATH=tsconfig.dev.json pnpm exec tsx watch cmd/main.ts",
    "dev:worker": "wrangler dev",
    "dev:prod-db": "wrangler dev --remote",
    "build": "pnpm --filter @repo/utils build && pnpm --filter @repo/content build && tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "start": "node dist/cmd/main.js",
    "lint": "eslint .",
    "typecheck": "pnpm --filter @repo/utils build && pnpm --filter @repo/content build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.6",
    "@repo/content": "workspace:*",
    "@repo/utils": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.10.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "typescript-eslint": "^8.58.0",
    "wrangler": "^4.81.1"
  }
}
