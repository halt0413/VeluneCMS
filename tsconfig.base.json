{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@repo/github": ["./packages/github/src/index.ts"],
      "@repo/content": ["./packages/content/src/index.ts"],
      "@velune-cms/client": ["./packages/cms-client/src/index.ts"],
      "@repo/utils": ["./packages/utils/src/index.ts"]
    }
  }
}
